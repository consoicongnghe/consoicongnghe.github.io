"ThreeFingerTapAction"=dword:00000004

; Extend pause windows update duration menu
; https://www.majorgeeks.com/content/page/how_to_pause_windows_updates_for_longer_than_5_weeks_or_as_long_as_you_want.html
[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings]
"FlightSettingsMaxPauseDays"=dword:0000016c